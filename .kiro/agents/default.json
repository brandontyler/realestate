{
  "name": "default",
  "description": "Default agent for real estate discussions",
  "tools": [
    "@builtin"
  ],
  "allowedTools": [
    "@builtin"
  ],
  "model": "claude-opus-4.6-1m",
  "resources": [
    "file://AGENTS.md",
    "file://.kiro/memory.md",
    "skill://~/.kiro/skills/dev-browser/SKILL.md",
    "skill://~/.kiro/skills/pdf-report/SKILL.md",
    "skill://.kiro/skills/mls/SKILL.md",
    "skill://.kiro/skills/cma/SKILL.md",
    "skill://.kiro/skills/listing-writer/SKILL.md",
    "skill://.kiro/skills/net-sheet/SKILL.md",
    "skill://.kiro/skills/deadline-tracker/SKILL.md"
  ],
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": ".kiro/hooks/dcg-guard.sh",
        "description": "DCG: Block destructive commands (rm -rf, git reset --hard, force push, etc.)"
      }
    ]
  }
}
